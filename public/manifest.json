{
    "manifest_version": 3,
    "name": "ModSAES (IPN SAES Helper)",
    "short_name": "ModSAES",
    "version": "1.0.0",
    "description": "Mejora tu experiencia en SAES IPN con visualización inteligente de horarios, detección de empalmes y selección dinámica de materias.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches" : [
                "*://*.ipn.mx/Academica/horarios.aspx",
                "*://*.ipn.mx/academica/horarios.aspx"
            ], 
            "js": ["content.js"], 
            "run_at": "document_idle"
        }, {
            "matches" : ["*://*.ipn.mx/*"], 
            "css": ["styles.css"], 
            "run_at": "document_idle"
        }
    ]
}
